# Cloudflare R2 public URL for downloading the raw JSON data sources
# R2_PUBLIC_URL=https://pub-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.r2.dev

# Cloudflare R2 credentials for uploading the raw JSON data sources
# R2_ACCOUNT_ID=your_account_id
# R2_ACCESS_KEY_ID=your_access_key
# R2_SECRET_ACCESS_KEY=your_secret_key
# R2_BUCKET=your_bucket_name

# Archive.org access keys for archiving web pages via Save Page Now
# So that the page can be cited in pindata and flipcommons
# ARCHIVE_ORG_ACCESS_KEY=your_access_key
# ARCHIVE_ORG_SECRET_KEY=your_secret_key